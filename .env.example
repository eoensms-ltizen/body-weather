NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
# Legacy generic-script compatibility only. New Plausible snippets do not need this value.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional custom MapLibre style.
NEXT_PUBLIC_MAP_STYLE_URL=
